{
  "info": {
    "name": "MILAN-SETU API",
    "description": "Complete API collection for MILAN-SETU matrimonial platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "csrf_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Get CSRF Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var data = pm.response.json();",
                  "if (data.csrfToken) {",
                  "    pm.collectionVariables.set('csrf_token', data.csrfToken);",
                  "    console.log('CSRF token saved:', data.csrfToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/milansetu/signup/",
              "host": ["{{base_url}}"],
              "path": ["api", "milansetu", "signup", ""]
            },
            "description": "Fetches the CSRF token. Run this before Signup. Token is auto-saved to collection variable."
          },
          "response": []
        },
        {
          "name": "Signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var data = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', data.access);",
                  "    pm.collectionVariables.set('refresh_token', data.refresh);",
                  "    console.log('Tokens saved. User ID:', data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-CSRFToken",
                "value": "{{csrf_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ravi.kumar@example.com\",\n  \"password\": \"SecurePass123\",\n  \"confirm_password\": \"SecurePass123\",\n  \"phone\": \"+919876543210\",\n  \"full_name\": \"Ravi Kumar\",\n  \"age\": 28,\n  \"height_cm\": 175,\n  \"religion\": \"Hindu\",\n  \"mother_tongue\": \"Hindi\",\n  \"marital_status\": \"never_married\",\n  \"father_occupation\": \"Business\",\n  \"mother_occupation\": \"Homemaker\",\n  \"siblings_count\": 1,\n  \"siblings_details\": \"One younger sister\",\n  \"family_values\": \"Traditional\",\n  \"industry\": \"Information Technology\",\n  \"education\": \"B.Tech Computer Science\",\n  \"current_designation\": \"Software Engineer\",\n  \"current_company\": \"Infosys\",\n  \"annual_income_min\": 800000.00,\n  \"annual_income_max\": 1200000.00,\n  \"income_unit\": \"INR\",\n  \"date_of_birth\": \"1996-06-15\",\n  \"time_of_birth\": \"10:30:00\",\n  \"birth_place\": \"New Delhi\",\n  \"zodiac_sign\": \"Gemini\",\n  \"manglik_status\": \"no\",\n  \"kundali_url\": \"https://example.com/kundali/ravi.pdf\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/milansetu/signup/",
              "host": ["{{base_url}}"],
              "path": ["api", "milansetu", "signup", ""]
            },
            "description": "Register a new user. Run 'Get CSRF Token' first. Access & refresh tokens are auto-saved."
          },
          "response": []
        },
        {
          "name": "Signup (Minimal - Email & Password Only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var data = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', data.access);",
                  "    pm.collectionVariables.set('refresh_token', data.refresh);",
                  "    console.log('Tokens saved. User ID:', data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-CSRFToken",
                "value": "{{csrf_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"minimal.user@example.com\",\n  \"password\": \"SecurePass123\",\n  \"confirm_password\": \"SecurePass123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/milansetu/signup/",
              "host": ["{{base_url}}"],
              "path": ["api", "milansetu", "signup", ""]
            },
            "description": "Register with only required fields. Profile fields can be filled later."
          },
          "response": []
        },
        {
          "name": "Login (Get JWT Token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var data = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', data.access);",
                  "    pm.collectionVariables.set('refresh_token', data.refresh);",
                  "    console.log('Tokens saved.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ravi.kumar@example.com\",\n  \"password\": \"SecurePass123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/token/",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "token", ""]
            },
            "description": "Login with email and password. Access & refresh tokens are auto-saved to collection variables."
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var data = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', data.access);",
                  "    if (data.refresh) {",
                  "        pm.collectionVariables.set('refresh_token', data.refresh);",
                  "    }",
                  "    console.log('Access token refreshed.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/token/refresh/",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "token", "refresh", ""]
            },
            "description": "Get a new access token using the refresh token."
          },
          "response": []
        },
        {
          "name": "Verify Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{access_token}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/token/verify/",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "token", "verify", ""]
            },
            "description": "Verify whether a JWT access token is still valid."
          },
          "response": []
        }
      ]
    },
