# Copy to .env and fill in values. On Render, set these in the dashboard.

SECRET_KEY=change-me
JWT_SIGNING_KEY=change-me
DEBUG=False

# Hostnames only — no http:// and no port numbers
ALLOWED_HOSTS=127.0.0.1,localhost,gprasadreddyofficial-lab.github.io,milansetu-backend.onrender.com

# Render auto-injects DATABASE_URL when the Postgres service is linked.
# Prefer DATABASE_URL; individual vars below are a local-dev fallback.
DATABASE_URL=

DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
